<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="agent_tier_view_form" model="ir.ui.view">
            <field name="name">agent_tier_view_form</field>
            <field name="model">agent.tier</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="min_sales_amount"/>
                                <field name="currency_id"/>
                                <field name="partner_count"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Mô tả">
                                <field name="description" widget="html"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="agent_tier_view_list" model="ir.ui.view">
            <field name="name">agent_tier_view_list</field>
            <field name="model">agent.tier</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="agent_tier_action" model="ir.actions.act_window">
            <field name="name">Hạng khách hàng</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">agent.tier</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="res_partner_agent_tier" name="Hạng khách hàng" action="custom_contact.agent_tier_action"
                  parent="contacts.res_partner_menu_config" sequence="3"/>
    </data>
</odoo>