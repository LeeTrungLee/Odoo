<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="agent_tier_view_form" model="ir.ui.view">
            <field name="name">agent_tier_view_form</field>
            <field name="model">agent.tier</field>
            <field name="arch" type="xml">
                <form>
                    <widget name="web_ribbon" title="Đã lưu trữ" bg_color="text-bg-danger" invisible="active"/>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="min_sales_amount"/>
                                <field name="currency_id"
                                       options='{"no_open": True, "no_create": True}'/>
                                <field name="partner_count"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Mô tả">
                                <field name="description" widget="html"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="agent_tier_view_list" model="ir.ui.view">
            <field name="name">agent_tier_view_list</field>
            <field name="model">agent.tier</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="min_sales_amount" width="150%"/>
                    <field name="partner_count" width="150%"/>
                </list>
            </field>
        </record>

        <record id="agent_tier_view_search" model="ir.ui.view">
            <field name="name">agent.tier.view.search</field>
            <field name="model">agent.tier</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm hạng khách hàng">
                    <filter name="filter_archived"
                            string="Đã lưu trữ"
                            domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="agent_tier_action" model="ir.actions.act_window">
            <field name="name">Hạng khách hàng</field>
            <field name="type">ir.actions.act_window</field>
            <field name="search_view_id" ref="agent_tier_view_search"/>
            <field name="res_model">agent.tier</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="res_partner_agent_tier" name="Hạng khách hàng" action="custom_contact.agent_tier_action"
                  parent="contacts.res_partner_menu_config" sequence="3"/>
    </data>
</odoo>