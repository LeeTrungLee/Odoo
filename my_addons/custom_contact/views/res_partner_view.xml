<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_inherit" model="ir.ui.view">
            <field name="name">view.partner.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="x_contact_code" placeholder="Mã đối tác"/>
                    <field name="x_partner_type"/>
                    <field name="x_partner_group"
                           string="Nhóm đối tác"
                           invisible="x_partner_type != 'partner'"
                           required="x_partner_type == 'partner'"/>
                    <field name="x_supplier_group"
                           string="Nhóm đối tác"
                           invisible="x_partner_type != 'supplier'"
                           required="x_partner_type == 'supplier'"/>
                </xpath>

                <xpath expr="//div[hasclass('o_address_format')]" position="after">
                    <field name="x_region" readonly="1" invisible="not x_region"/>
                    <field name="x_birthday" options="{'numeric': true}" placeholder="Ngày sinh"/>
                    <field name="x_identification_number" placeholder="Số Căn Cước Công dân"/>
                </xpath>

                <xpath expr="//field[@name='city']" position="attributes">
                    <attribute name="placeholder">Xã</attribute>
                </xpath>

                <xpath expr="//field[@name='state_id']" position="attributes">
                    <attribute name="placeholder">Tỉnh/Thành Phố</attribute>
                    <attribute name="required">is_company == True</attribute>
                </xpath>

                <xpath expr="//field[@name='street']" position="attributes">
                    <attribute name="required">is_company == True</attribute>
                </xpath>

                <xpath expr="//field[@name='vat']" position="replace">
                    <field name="vat" required="1" placeholder="Mã số thuế"/>
                </xpath>

                <xpath expr="//field[@name='phone']" position="attributes">
                    <attribute name="required">1</attribute>
                </xpath>

                <xpath expr="//field[@name='country_id']" position="attributes">
                    <attribute name="required">is_company == True</attribute>
                </xpath>

                <xpath expr="//page[@name='sales_purchases']//field[@name='user_id']" position="after">
                    <field name="x_is_internal"/>
                </xpath>

                <xpath expr="//page[@name='sales_purchases']" position="after">
                    <page string="Quản lý đối tác">
                        <group>
                            <group string="Hạng khách hàng">
                                <field name="x_customer_tier_id" options='{"no_open": True, "no_create": True}'
                                       readonly="True"/>
                                <field name="x_total_sales_amount" invisible="True"/>
                            </group>
                            <group string="Nhân viên phụ trách">
                                <field name="x_salesperson_id" options='{"no_open": True, "no_create": True}'/>
                                <field name="x_salesperson_ids" widget="many2many_tags"
                                       options='{"no_open": True, "no_create": True}'
                                       domain="[('id', 'not in', x_salesperson_ids), ('id', '!=', x_salesperson_id)]"/>
                            </group>
                        </group>
                    </page>
                    <page string="Công nợ">
                        <group>
                            <group string="Hạn mức">
                                <field name="x_credit_limit"/>
                                <field name="x_credit_available" readonly="True"/>
                            </group>
                            <group string="Công nợ">
                                <field name="x_credit_used" readonly="True"/>
                                <field name="x_credit_overdue" readonly="True"/>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="contacts.action_contacts" model="ir.actions.act_window">
            <field name="view_mode">kanban,list,form,activity</field>
            <field name="context">{'search_default_partner_supplier_filter': 1}</field>
        </record>

        <record id="contacts.action_contacts_view_kanban" model="ir.actions.act_window.view">
            <field name="sequence" eval="0"/>
        </record>

        <record id="contacts.action_contacts_view_tree" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
        </record>

        <record id="view_res_partner_filter_inherit_custom" model="ir.ui.view">
            <field name="name">res.partner.search.inherit.custom</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_res_partner_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <filter name="partner_supplier_filter"
                            string="Khách hàng &amp; Nhà cung cấp"
                            domain="[('x_partner_type', 'in', ['partner', 'supplier'])]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>