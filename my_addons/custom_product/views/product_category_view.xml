<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_category_form_view_inherit_custom" model="ir.ui.view">
            <field name="name">product.category.form.view.inherit.custom</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='first']" position="after">
                    <group>
                        <field name="barcode_prefix"/>l
                    </group>
                    <notebook>
                        <page string="Cấu hình thuộc tính">
                            <field name="attr_ids" widget="one2many">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="attribute_id" options='{"no_open": True, "no_create": True}'/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>
    </data>
</odoo>