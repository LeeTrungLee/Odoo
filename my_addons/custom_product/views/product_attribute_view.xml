<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_attribute_view_form_inherit" model="ir.ui.view">
            <field name="name">product.attribute.view_form_inherit</field>
            <field name="model">product.attribute</field>
            <field name="inherit_id" ref="product.product_attribute_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='create_variant']" position="after">
                    <field name="is_degree" widget="boolean_toggle"/>
                    <field name="symbol_degree" invisible="is_degree == False"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>